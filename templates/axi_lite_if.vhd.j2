-- =============================================================================
-- AUTO-GENERATED by axi_wrapper -- DO NOT EDIT MANUALLY
-- Source entity : {{ ir.entity_name }}
-- Register width: {{ ir.register_width }} bits
-- Registers     : {{ ir.registers | length }}
--
-- Port direction convention (from the AXI interface perspective):
--   RW / WO fields  -> register drives DUT input -> port is OUT on this entity
--   RO fields       -> DUT output drives register -> port is IN  on this entity
-- =============================================================================
library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity axi_lite_if is
  generic (
    C_S_AXI_DATA_WIDTH : integer := {{ ir.register_width }};
    C_S_AXI_ADDR_WIDTH : integer := {{ ir.addr_bits }}
  );
  port (
    -- AXI4-Lite clock and reset
    S_AXI_ACLK    : in  std_logic;
    S_AXI_ARESETN : in  std_logic;

    -- Write address channel
    S_AXI_AWADDR  : in  std_logic_vector(C_S_AXI_ADDR_WIDTH-1 downto 0);
    S_AXI_AWPROT  : in  std_logic_vector(2 downto 0);
    S_AXI_AWVALID : in  std_logic;
    S_AXI_AWREADY : out std_logic;

    -- Write data channel
    S_AXI_WDATA   : in  std_logic_vector(C_S_AXI_DATA_WIDTH-1 downto 0);
    S_AXI_WSTRB   : in  std_logic_vector((C_S_AXI_DATA_WIDTH/8)-1 downto 0);
    S_AXI_WVALID  : in  std_logic;
    S_AXI_WREADY  : out std_logic;

    -- Write response channel
    S_AXI_BRESP   : out std_logic_vector(1 downto 0);
    S_AXI_BVALID  : out std_logic;
    S_AXI_BREADY  : in  std_logic;

    -- Read address channel
    S_AXI_ARADDR  : in  std_logic_vector(C_S_AXI_ADDR_WIDTH-1 downto 0);
    S_AXI_ARPROT  : in  std_logic_vector(2 downto 0);
    S_AXI_ARVALID : in  std_logic;
    S_AXI_ARREADY : out std_logic;

    -- Read data channel
    S_AXI_RDATA   : out std_logic_vector(C_S_AXI_DATA_WIDTH-1 downto 0);
    S_AXI_RRESP   : out std_logic_vector(1 downto 0);
    S_AXI_RVALID  : out std_logic;
    S_AXI_RREADY  : in  std_logic;

    -- RW/WO fields: register drives the DUT input port -- OUT on this entity
{% for reg in ir.registers %}
{% for fld in reg.fields %}
{% set port = ir.port_by_name(fld.port_name) %}
{% if fld.access.value in ['RW', 'WO'] %}
    {{ fld.port_name | ljust(30) }}: out {{ port.vhdl_type }};
{% endif %}
{% endfor %}
{% endfor %}

    -- RO fields: DUT output port drives the register -- IN on this entity
{% for reg in ir.registers %}
{% for fld in reg.fields %}
{% set port = ir.port_by_name(fld.port_name) %}
{% if fld.access.value == 'RO' %}
    {{ fld.port_name | ljust(30) }}: in  {{ port.vhdl_type }};
{% endif %}
{% endfor %}
{% endfor %}

    -- Dummy terminator (avoids trailing semicolon issues)
    dummy_unused : in std_logic := '0'
  );
end entity axi_lite_if;

architecture rtl of axi_lite_if is

  -- -------------------------------------------------------------------------
  -- AXI handshake internals
  -- -------------------------------------------------------------------------
  signal axi_awaddr  : std_logic_vector(C_S_AXI_ADDR_WIDTH-1 downto 0);
  signal axi_awready : std_logic;
  signal axi_wready  : std_logic;
  signal axi_bresp   : std_logic_vector(1 downto 0);
  signal axi_bvalid  : std_logic;
  signal axi_araddr  : std_logic_vector(C_S_AXI_ADDR_WIDTH-1 downto 0);
  signal axi_arready : std_logic;
  signal axi_rdata   : std_logic_vector(C_S_AXI_DATA_WIDTH-1 downto 0);
  signal axi_rresp   : std_logic_vector(1 downto 0);
  signal axi_rvalid  : std_logic;

  signal aw_en       : std_logic;

  -- -------------------------------------------------------------------------
  -- Register shadows (one per register in the map)
  -- -------------------------------------------------------------------------
{% for reg in ir.registers %}
  signal {{ reg.name | lower }}_reg : std_logic_vector(C_S_AXI_DATA_WIDTH-1 downto 0) := (others => '0');
{% endfor %}

  -- -------------------------------------------------------------------------
  -- Address word decode (drop 2 LSBs for byte to word addressing)
  -- -------------------------------------------------------------------------
  constant ADDR_LSB          : integer := (C_S_AXI_DATA_WIDTH / 32) + 1;
  constant OPT_MEM_ADDR_BITS : integer := C_S_AXI_ADDR_WIDTH - 1 - ADDR_LSB;

begin

  -- =========================================================================
  -- AXI channel output tie-offs

  -- =========================================================================
  S_AXI_AWREADY <= axi_awready;
  S_AXI_WREADY  <= axi_wready;
  S_AXI_BRESP   <= axi_bresp;
  S_AXI_BVALID  <= axi_bvalid;
  S_AXI_ARREADY <= axi_arready;
  S_AXI_RDATA   <= axi_rdata;
  S_AXI_RRESP   <= axi_rresp;
  S_AXI_RVALID  <= axi_rvalid;

  -- =========================================================================
  -- Write address channel: AWREADY / AW_EN

  -- =========================================================================

  p_awready : process(S_AXI_ACLK)
  begin
    if rising_edge(S_AXI_ACLK) then
      if S_AXI_ARESETN = '0' then
        axi_awready <= '0';
        aw_en       <= '1';
      else
        if aw_en = '1' and S_AXI_AWVALID = '1' and S_AXI_WVALID = '1' then
          axi_awready <= '1';
          aw_en       <= '0';
        elsif S_AXI_BREADY = '1' and axi_bvalid = '1' then
          aw_en <= '1';
        else
          axi_awready <= '0';
        end if;
      end if;
    end if;
  end process p_awready;

  p_awaddr : process(S_AXI_ACLK)
  begin
    if rising_edge(S_AXI_ACLK) then
      if S_AXI_ARESETN = '0' then
        axi_awaddr <= (others => '0');
      else
        if aw_en = '1' and S_AXI_AWVALID = '1' and S_AXI_WVALID = '1' then
          axi_awaddr <= S_AXI_AWADDR;
        end if;
      end if;
    end if;
  end process p_awaddr;

  -- =========================================================================
  -- Write data channel: WREADY

  -- =========================================================================

  p_wready : process(S_AXI_ACLK)
  begin
    if rising_edge(S_AXI_ACLK) then
      if S_AXI_ARESETN = '0' then
        axi_wready <= '0';
      else
        if aw_en = '1' and S_AXI_AWVALID = '1' and S_AXI_WVALID = '1' then
          axi_wready <= '1';
        else
          axi_wready <= '0';
        end if;
      end if;
    end if;
  end process p_wready;

  -- =========================================================================
  -- Register write process
  --   CPU write path : AXI write data captured into shadow register
  --   RO capture     : DUT output port value latched into shadow each cycle

  -- =========================================================================

  p_reg_write : process(S_AXI_ACLK)
    variable loc_addr : std_logic_vector(OPT_MEM_ADDR_BITS downto 0);
  begin
    if rising_edge(S_AXI_ACLK) then
      if S_AXI_ARESETN = '0' then
{% for reg in ir.registers %}
        {{ reg.name | lower }}_reg <= (others => '0');
{% endfor %}
      else

        -- CPU write path
        if axi_awready = '1' and S_AXI_AWVALID = '1' and
           axi_wready  = '1' and S_AXI_WVALID  = '1' then

          loc_addr := axi_awaddr(ADDR_LSB + OPT_MEM_ADDR_BITS downto ADDR_LSB);

          case loc_addr is
{% for reg in ir.registers %}
{% set word_addr = reg.offset // 4 %}
            when b"{{ word_addr | bin_addr(ir.addr_bits - 2) }}" =>
{% for byte_idx in range(ir.register_width // 8) %}
              if S_AXI_WSTRB({{ byte_idx }}) = '1' then
                {{ reg.name | lower }}_reg({{ byte_idx * 8 + 7 }} downto {{ byte_idx * 8 }}) <=
                  S_AXI_WDATA({{ byte_idx * 8 + 7 }} downto {{ byte_idx * 8 }});
              end if;
{% endfor %}
{% endfor %}
            when others => null;
          end case;
        end if;

        -- RO capture: DUT output continuously updates shadow register
{% for reg in ir.registers %}
{% for fld in reg.fields %}
{% if fld.access.value == 'RO' %}
{% set port = ir.port_by_name(fld.port_name) %}
{% if port.width == 1 %}
        {{ reg.name | lower }}_reg({{ fld.bit_high }}) <= {{ fld.port_name }};
{% else %}
        {{ reg.name | lower }}_reg({{ fld.bit_high }} downto {{ fld.bit_low }}) <= {{ fld.port_name }};
{% endif %}
{% endif %}
{% endfor %}
{% endfor %}

      end if;
    end if;
  end process p_reg_write;

  -- =========================================================================
  -- Write response channel

  -- =========================================================================

  p_bresp : process(S_AXI_ACLK)
  begin
    if rising_edge(S_AXI_ACLK) then
      if S_AXI_ARESETN = '0' then
        axi_bvalid <= '0';
        axi_bresp  <= "00";
      else
        if axi_awready = '1' and S_AXI_AWVALID = '1' and
           axi_wready  = '1' and S_AXI_WVALID  = '1' and
           axi_bvalid  = '0' then
          axi_bvalid <= '1';
          axi_bresp  <= "00";  -- OKAY
        elsif S_AXI_BREADY = '1' and axi_bvalid = '1' then
          axi_bvalid <= '0';
        end if;
      end if;
    end if;
  end process p_bresp;

  -- =========================================================================
  -- Read address channel: ARREADY

  -- =========================================================================

  p_arready : process(S_AXI_ACLK)
  begin
    if rising_edge(S_AXI_ACLK) then
      if S_AXI_ARESETN = '0' then
        axi_arready <= '0';
        axi_araddr  <= (others => '1');
      else
        if axi_arready = '0' and S_AXI_ARVALID = '1' then
          axi_arready <= '1';
          axi_araddr  <= S_AXI_ARADDR;
        else
          axi_arready <= '0';
        end if;
      end if;
    end if;
  end process p_arready;

  -- =========================================================================
  -- Read data channel: RDATA / RVALID
  --   All non-WO fields read from the shadow register.
  --   RO shadows are updated every cycle from the DUT port in p_reg_write.

  -- =========================================================================

  p_rdata : process(S_AXI_ACLK)
    variable loc_addr : std_logic_vector(OPT_MEM_ADDR_BITS downto 0);
  begin
    if rising_edge(S_AXI_ACLK) then
      if S_AXI_ARESETN = '0' then
        axi_rvalid <= '0';
        axi_rresp  <= "00";
        axi_rdata  <= (others => '0');
      else
        if axi_arready = '1' and S_AXI_ARVALID = '1' and axi_rvalid = '0' then
          axi_rvalid <= '1';
          axi_rresp  <= "00";

          loc_addr := axi_araddr(ADDR_LSB + OPT_MEM_ADDR_BITS downto ADDR_LSB);
          axi_rdata <= (others => '0');

          case loc_addr is
{% for reg in ir.registers %}
{% set word_addr = reg.offset // 4 %}
            when b"{{ word_addr | bin_addr(ir.addr_bits - 2) }}" =>
{% for fld in reg.fields %}
{% if fld.access.value != 'WO' %}
{% if fld.width == 1 %}
              axi_rdata({{ fld.bit_high }}) <= {{ reg.name | lower }}_reg({{ fld.bit_high }});
{% else %}
              axi_rdata({{ fld.bit_high }} downto {{ fld.bit_low }}) <=
                {{ reg.name | lower }}_reg({{ fld.bit_high }} downto {{ fld.bit_low }});
{% endif %}
{% endif %}
{% endfor %}
{% endfor %}
            when others => axi_rdata <= (others => '0');
          end case;

        elsif axi_rvalid = '1' and S_AXI_RREADY = '1' then
          axi_rvalid <= '0';
        end if;
      end if;
    end if;
  end process p_rdata;

  -- =========================================================================
  -- Concurrent assignments: shadow registers -> DUT input ports
  --   RW : CPU can write; register value continuously drives the DUT input
  --   WO : same, but reads return '0'

  -- =========================================================================
{% for reg in ir.registers %}
{% for fld in reg.fields %}
{% if fld.access.value in ['RW', 'WO'] %}
{% set port = ir.port_by_name(fld.port_name) %}
{% if port.width == 1 %}
  {{ fld.port_name }} <= {{ reg.name | lower }}_reg({{ fld.bit_high }});
{% else %}
  {{ fld.port_name }} <= {{ reg.name | lower }}_reg({{ fld.bit_high }} downto {{ fld.bit_low }});
{% endif %}
{% endif %}
{% endfor %}
{% endfor %}

end architecture rtl;
